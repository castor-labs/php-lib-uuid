{
  "name": "castor/uuid",
  "version": "3.1.0",
  "description": "An RFC-4122 compliant Universally Unique Identifiers value object implementation",
  "keywords": [
    "castor",
    "guid",
    "identifier",
    "php",
    "php83",
    "rfc4122",
    "uuid",
    "uuid-v1",
    "uuid-v4",
    "uuid-v7"
  ],
  "homepage": "https://castor-labs.github.io/php-lib-uuid/",
  "minimum-stability": "stable",
  "license": "MIT",
  "authors": [
    {
      "name": "Matias Navarro Carter",
      "email": "mnavarrocarter@gmail.com",
      "role": "Lead Maintainer"
    }
  ],
  "autoload": {
    "psr-4": {
      "Castor\\": "src"
    },
    "files": [
      "include/functions.php"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "Castor\\": "tests"
    }
  },
  "repositories": [
    {
      "type": "composer",
      "url": "https://castor-labs.github.io/php-packages"
    }
  ],
  "require": {
    "brick/date-time": "^0.7",
    "castor/functions": "^1.0",
    "ext-bcmath": "*",
    "php": ">=8.3"
  },
  "require-dev": {
    "carthage-software/mago": "^1.27.1",
    "castor-labs/docs": "^0.1.0",
    "ergebnis/phpunit-slow-test-detector": "^2.10",
    "phpbench/phpbench": "^1.3",
    "phpunit/phpunit": "^10.5",
    "ramsey/uuid": "^4.7",
    "rector/rector": "^2.4"
  },
  "scripts": {
    "pr": [
      "@rector",
      "@mago:fmt",
      "@mago:lint",
      "@mago:analyze",
      "@test"
    ],
    "ci": [
      "@rector:check",
      "@mago:fmt:check",
      "@mago:lint",
      "@mago:analyze",
      "@test"
    ],
    "mago": [
      "@mago:fmt",
      "@mago:lint",
      "@mago:analyze"
    ],
    "rector": "rector process",
    "rector:check": "rector process --dry-run",
    "mago:fmt": "mago fmt",
    "mago:fmt:check": "mago fmt --dry-run",
    "mago:analyze": "mago analyze --sort",
    "mago:lint": "mago lint --sort",
    "mago:lint:baseline:fix": "mago lint --sort --generate-baseline --backup-baseline",
    "mago:lint:baseline:check": "mago lint --sort --verify-baseline",
    "mago:analyze:baseline:check": "mago analyze --sort --verify-baseline",
    "mago:analyze:baseline:fix": "mago analyze --sort --generate-baseline --backup-baseline",
    "test": "phpunit --colors",
    "test:unit": "phpunit --colors --exclude-group=integration,e2e,dbal,bundle",
    "test:e2e": "phpunit --colors --group=e2e",
    "test:integration": "phpunit --colors --group=integration,dbal,bundle",
    "bench": "phpbench run --report=default --output=html tests/Benchmark",
    "profile": "phpbench xdebug:profile tests/Benchmark --progress=none",
    "docs:build": "vendor/bin/castor-docs generate --source=.dev/docs --target=.dev/docs-dist",
    "docs:check": [
      "@docs:build",
      "test -f .dev/docs-dist/index.html"
    ]
  },
  "config": {
    "allow-plugins": {
      "carthage-software/mago": true
    },
    "sort-packages": true
  }
}
